{
  "name": "@florasync/harmonogram-elements",
  "version": "0.1.0",
  "description": "Standards-based custom elements for Harmonogram",
  "author": "FloraSync",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./src/harmonogram-board.ts",
    "./src/harmonogram-wc.ts",
    "./src/register.ts",
    "./dist/harmonogram-board.js",
    "./dist/harmonogram-wc.js",
    "./dist/register.js",
    "./dist/harmonogram-elements.js"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/harmonogram-elements.js",
  "jsdelivr": "dist/harmonogram-elements.js",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FloraSync/harmonogram-wc.git",
    "directory": "packages/elements"
  },
  "bugs": {
    "url": "https://github.com/FloraSync/harmonogram-wc/issues"
  },
  "homepage": "https://github.com/FloraSync/harmonogram-wc/tree/main/packages/elements#readme",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./bundle": "./dist/harmonogram-elements.js"
  },
  "browser": {
    "./register": "./dist/register.js",
    "./bundle": "./dist/harmonogram-elements.js"
  },
  "typesVersions": {
    "*": {
      "register": [
        "./dist/register.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/build-browser-bundle.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "test": "wtr --coverage --config web-test-runner.config.js",
    "test:smoke": "npm run build && wtr --config web-test-runner.config.js --files smoke/package-contract-smoke.test.js",
    "test:watch": "wtr --watch --config web-test-runner.config.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepack": "npm run build",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@florasync/harmonogram-core": "0.1.0",
    "lit": "^3.3.2"
  },
  "keywords": [
    "florasync",
    "harmonogram",
    "web-component",
    "schedule",
    "lit"
  ]
}
